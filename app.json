{
  "expo": {
    "name": "Nutrisee",
    "slug": "nutrisee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ICON_N.png",
    "scheme": "nutrisee",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/images/ICON_N.png"
    },
    "android": {
      "icon": "./assets/images/ICON_N.png",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/ICON_N.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ],
      "package": "com.anonymous.Nutrisee"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/ICON_N.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/bg/SPLASH_Background.png",
          "resizeMode": "cover",
          "backgroundColor": "#1a237e",
          "dark": {
            "backgroundColor": "#1a237e"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Nutrisee to access your photos.",
          "cameraPermission": "Allow Nutrisee to take photos of your meals."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Nutrisee to access your camera to scan meals."
        }
      ],
      "expo-localization",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b1369aa7-2956-4b03-b642-d79d52eb38ca"
      }
    },
    "owner": "mono-type"
  }
}
